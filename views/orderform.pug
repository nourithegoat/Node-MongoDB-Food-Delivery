doctype html 
html 
    head 
        title Order Form 
        link(rel="stylesheet", href="/style.css")

        style. 
            .column {
                float: left;
            }
            .left {
                width: 10%;
            }
            .middle {
                width: 65%;
            }
            .right {
                width: 25%;
            }
    body(onload="init()")
        header  
            h1 Food Delivery
            ul
                li: a(href="/") Home 
                li: a(href="/orders") Order 
                li: a(href="/users") Users
                if currentUser
                    li: a(href=`/users/${currentUser.id}`) Profile
                    li: a(href="/logout") Logout 
                    li Loggind in as #{currentUser.username}
                else
                    li: a(href="/register") Register 
                    li: a(href = "/login") Login
        main
            select#restaurant-select 
            br
            br
            #info
            #main 
                .column.left#left 
                .column.middle#middle 
                .column.right#right
        script(src="/orderform.js")